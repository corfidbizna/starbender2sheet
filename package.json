		"eslint": "^10.5.0",
		"eslint-plugin-vue": "^10.9.2",
		"jiti": "^2.7.0",
		"jsdom": "^29.1.1",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.4",
